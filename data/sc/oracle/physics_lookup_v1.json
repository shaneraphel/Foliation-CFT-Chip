{
  "schema": "foliation.physics_lookup.v1",
  "version": "1.0.0",
  "deterministic": true,
  "description": "Hard-coded Pauling EN + Shannon ionic radii for Top-10 sweep-pool elements. No ML, no sampling.",
  "sources": {
    "pauling_en": "Pauling (1960) scale; CRC Handbook typical values",
    "shannon_radius_pm": "Shannon & Prewitt (1970); VI coordination unless noted"
  },
  "decode_rules": {
    "E_k_eV": {
      "formula": "E_k ≈ alpha * |chi_TM - chi_L| + beta * E_shift_eV",
      "alpha_eV_per_delta_chi": 1.85,
      "beta": 1.0,
      "E_shift_eV": 0.35,
      "tolerance_eV": 0.75,
      "comment": "Bath level tracks ligand–TM electronegativity gap; both keys must match interval."
    },
    "V_k_eV": {
      "formula": "V_k ≈ gamma * exp(-d / a0) * overlap_scale",
      "gamma": 0.42,
      "a0_A": 0.52,
      "overlap_scale": "1 - (r_TM + r_L) / (2 * d_bond_A)",
      "d_bond_default_A": 2.45,
      "tolerance_eV": 0.35,
      "comment": "Hybridization scales with Shannon overlap; smaller radii → larger V_k band."
    },
    "U_eV": {
      "formula": "U in tm_d_u_eV[family].window",
      "tolerance_eV": 0.8,
      "comment": "Hubbard U selects transition-metal family, not individual bath index."
    },
    "Mu_eV": {
      "formula": "mu vs mu_ref_eV → dopant_hint",
      "mu_ref_eV": 0.0,
      "delta_mu_donor_eV": -0.25,
      "delta_mu_acceptor_eV": 0.25,
      "comment": "mu below ref → electron donor (e.g. Ta5+ on Mo4+ site); above → acceptor."
    },
    "pair_filter": {
      "rule": "Keep (TM, L) iff all bath k satisfy E_k and V_k bands simultaneously",
      "multi_solution": "List all pairs passing constraints; rank by total band violation (L1), no softmax"
    },
    "mu_discrete_reverse": {
      "mu_ref_eV": 0.0,
      "mu_per_dopant_fraction_eV": 0.45,
      "dopant_activation_threshold_eV": 0.5,
      "formula_forward": "mu_discrete = mu_ref_eV + mu_per_dopant_fraction_eV * x_discrete",
      "formula_inverse": "x_theory = 0 if |mu_theta-mu_ref| < threshold else piecewise linear toward mu_ref",
      "comment": "x>max requires FAIL_FRAGILE unless lower-x grid passes FPU; slope calibrated for 4d TMD μ scale",
      "max_dopant_fraction": 0.25
    }
  },
