#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$ROOT/bin/chip-icloud-env.sh"
export PASS_V1_ROOT="${PASS_V1_ROOT:-$HOME/Desktop/foliation-pass-v1}"
"$ROOT/bin/chip-cft-materialize" >/dev/null
"$ROOT/bin/chip-physics-sim" >/dev/null
export CHIP_FLEET_PYTHON="${CHIP_FLEET_PYTHON:-/usr/local/bin/python3}"
export FOLIATION_QE_OMP="${FOLIATION_QE_OMP:-2}"
export KILLER_PIPELINE_TIMEOUT="${KILLER_PIPELINE_TIMEOUT:-7200}"
export FOLIATION_PROXY="${FOLIATION_PROXY:-http://127.0.0.1:7892}"
export HTTP_PROXY="${HTTP_PROXY:-$FOLIATION_PROXY}"
export HTTPS_PROXY="${HTTPS_PROXY:-$FOLIATION_PROXY}"
exec "$CHIP_FLEET_PYTHON" "$ROOT/tools/chip_hot_restart_fleet.py" "$@"
